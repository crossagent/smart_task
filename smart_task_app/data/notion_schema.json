{
  "version": "1.1",
  "architecture": "5-Database",
  "modification_rule": "Always write from CHILD to PARENT (Atomic). Never fetch-append-patch on parents.",
  "databases": {
    "Initiative": {
      "role": "Grandparent / Request View",
      "properties": {
        "Name": {"type": "title"},
        "Requester": {"type": "rich_text"},
        "Initiator": {"type": "relation", "target": "Resource"},
        "Status": {"type": "status"}
      }
    },
    "Feature": {
      "role": "Parent / Business Goal",
      "properties": {
        "Name": {"type": "title"},
        "Initiative": {"type": "relation", "target": "Initiative"},
        "Priority": {"type": "select", "options": ["P0", "P1", "P2"]},
        "Owner": {"type": "relation", "target": "Resource"},
        "Status": {"type": "status"},
        "Target_Date": {"type": "date"}
      },
      "relational_logic": "Must link to Initiative ID upon creation."
    },
    "Task": {
      "role": "Child / Execution Unit",
      "properties": {
        "Name": {"type": "title"},
        "Feature": {"type": "relation", "target": "Feature"},
        "Initiative": {"type": "relation", "target": "Initiative"},
        "Resource": {"type": "relation", "target": "Resource"},
        "Module": {"type": "relation", "target": "Module"},
        "Estimated_Hours": {"type": "number"},
        "Priority": {"type": "select", "options": ["P0", "P1", "P2"]},
        "Status": {"type": "status"},
        "Timeline": {"type": "date"}
      },
      "relational_logic": "Must link to Feature ID, Initiative ID, and Resource ID upon creation."
    },
    "Module": {
      "role": "Supporting / Physical Asset",
      "properties": {
        "Name": {"type": "title"},
        "Description": {"type": "rich_text"}
      }
    },
    "Resource": {
      "role": "Supporting / Bandwidth",
      "properties": {
        "Name": {"type": "title"},
        "Role": {"type": "select"},
        "Weekly_Capacity": {"type": "number"},
        "Status": {"type": "status"}
      }
    }
  }
}